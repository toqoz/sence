{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["proposedPolicy", "explanation", "resumeCommand"],
  "additionalProperties": false,
  "properties": {
    "proposedPolicy": {
      "type": "object",
      "description": "The complete new fence.json content",
      "required": ["extends", "network", "filesystem", "command"],
      "additionalProperties": false,
      "properties": {
        "extends": {
          "type": ["string", "null"],
          "description": "Base template to extend"
        },
        "network": {
          "type": ["object", "null"],
          "required": ["allowedDomains", "deniedDomains"],
          "additionalProperties": false,
          "properties": {
            "allowedDomains": {
              "type": ["array", "null"],
              "items": { "type": "string" }
            },
            "deniedDomains": {
              "type": ["array", "null"],
              "items": { "type": "string" }
            }
          }
        },
        "filesystem": {
          "type": ["object", "null"],
          "required": ["allowRead", "denyRead", "allowWrite", "denyWrite"],
          "additionalProperties": false,
          "properties": {
            "allowRead": {
              "type": ["array", "null"],
              "items": { "type": "string" }
            },
            "denyRead": {
              "type": ["array", "null"],
              "items": { "type": "string" }
            },
            "allowWrite": {
              "type": ["array", "null"],
              "items": { "type": "string" }
            },
            "denyWrite": {
              "type": ["array", "null"],
              "items": { "type": "string" }
            }
          }
        },
        "command": {
          "type": ["object", "null"],
          "required": ["deny"],
          "additionalProperties": false,
          "properties": {
            "deny": {
              "type": ["array", "null"],
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "explanation": {
      "type": "string",
      "description": "One short sentence explaining the policy change"
    },
    "resumeCommand": {
      "type": ["string", "null"],
      "description": "The shell command to resume the agent session, or null if unknown"
    }
  }
}
